{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "A career path analysis result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string" },
        "targetCareer": { "type": "object" },
        "programs": { "type": "array" },
        "institutes": { "type": "array" },
        "roadmap": { "type": "array" },
        "marketInsights": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/Analysis" },
      "description": "Stores individual analyses"
    }
  }
}
